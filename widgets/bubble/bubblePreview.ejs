<div x-data='bubblePreviewController(<%- JSON.stringify(bubbleSettings || {}) %>)'
  class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <style x-text="cssKeyframes()"></style>

  <div class="lg:col-span-2 flex flex-col gap-4">
    <div class="flex-1 flex items-center justify-center bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-16 min-h-[300px] relative transition-all duration-300">

      <div class="absolute top-4 right-4 flex space-x-2 z-10">
        <button @click="copySettings()"
          :class="copied ? 'bg-emerald-500 text-white' : 'bg-white dark:bg-slate-950 text-slate-600 dark:text-slate-400 border border-slate-200 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-900'"
          class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-bold shadow-sm transition-all duration-200 cursor-pointer">
          <svg x-show="!copied" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H5.4m1.5 13.5h9.75a1.125 1.125 0 0 0 1.125-1.125V7.875a1.125 1.125 0 0 0-1.125-1.125H5.4M9 13.5h5.625M9 16.5h5.625m-5.625-6h1.5m-1.5 3h1.5" /></svg>
          <svg x-show="copied" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5" style="display: none;"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
          <span x-text="copied ? 'Copied!' : 'Copy JSON'"></span>
        </button>

        <button @click="downloadSettings()"
          class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-bold bg-white dark:bg-slate-950 text-slate-600 dark:text-slate-400 border border-slate-200 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-900 shadow-sm transition-all duration-200 cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
          <span>Download</span>
        </button>

        <button @click="saveSettings()"
          :class="saved ? 'bg-emerald-500 text-white' : 'bg-indigo-600 hover:bg-indigo-500 text-white'"
          class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-bold shadow-sm transition-all duration-200 cursor-pointer">
          <svg x-show="!saved" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0 1 11.186 0Z" /></svg>
          <svg x-show="saved" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5" style="display: none;"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
          <span x-text="saved ? 'Saved!' : 'Save Widget'"></span>
        </button>
      </div>

      <div class="relative flex items-center justify-center transition-all duration-300 cursor-pointer" :style="{
          width: settings.width + 'px',
          height: settings.height + 'px',
          borderRadius: `${settings.borderRadius.tl}px ${settings.borderRadius.tr}px ${settings.borderRadius.br}px ${settings.borderRadius.bl}px`,
          background: getCompositeBackground(),
          backgroundBlendMode: settings.backgroundBlendMode,
          boxShadow: [getBoxShadow(), getInnerShadow()].filter(Boolean).join(', '),
          transformStyle: 'preserve-3d',
          ...getBorderStyle(),
          ...(settings.glass && settings.glass.enabled ? getGlassStyle() : {}),
          ...(settings.neon && settings.neon.enabled ? getNeonStyle() : {}),
          ...getEntryAnimStyle()
        }" @mouseenter="hovered = true" @mouseleave="hovered = false">
        <template x-if="settings.backgroundOverlayType === 'image' && settings.backgroundImageUrl">
          <div class="absolute inset-0 pointer-events-none" :style="{
              backgroundImage: `url(${settings.backgroundImageUrl})`,
              backgroundRepeat: 'no-repeat',
              backgroundPosition: 'center',
              backgroundSize: settings.backgroundImageSize,
              opacity: settings.backgroundImageOpacity,
              mixBlendMode: settings.backgroundBlendMode,
              borderRadius: 'inherit'
            }"></div>
        </template>

        <template x-if="settings.backgroundOverlayType === 'lucide' && settings.backgroundLucideIcon">
          <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none flex items-center justify-center" :style="{ opacity: settings.backgroundLucideOpacity, mixBlendMode: settings.backgroundBlendMode }">
            <i :data-lucide="settings.backgroundLucideIcon.toLowerCase()" :style="{ width: settings.backgroundLucideSize + 'px', height: settings.backgroundLucideSize + 'px', color: settings.backgroundLucideColor }"></i>
          </div>
        </template>

        <template x-if="settings.dots && hovered">
          <div class="absolute flex z-10" :style="{ gap: `${settings.dots.spacing}px` }">
            <template x-for="i in [0, 1, 2]">
              <span class="rounded-full" :style="{ width: `${settings.dots.size}px`, height: `${settings.dots.size}px`, backgroundColor: settings.dots.color, animation: settings.dots.animation === 'bounce' ? `dotBounce 1.2s cubic-bezier(.2,.8,.2,1) ${i * 0.12}s infinite` : settings.dots.animation === 'pulse' ? `dotPulse 1.4s cubic-bezier(.2,.8,.2,1) ${i * 0.1}s infinite` : 'none' }"></span>
            </template>
          </div>
        </template>

        <template x-if="settings.outlineRing && settings.outlineRing.enabled">
          <div aria-hidden class="pointer-events-none absolute inset-0" :style="{ borderRadius: 'inherit', boxShadow: `0 0 0 ${settings.outlineRing.width}px ${hexToRgba(settings.outlineRing.color, settings.outlineRing.opacity)}` }"></div>
        </template>
      </div>
    </div>

    <div class="glass-panel p-4 rounded-xl border border-slate-200/60 dark:border-slate-800/40">
      <span class="text-3xs font-extrabold uppercase tracking-widest text-slate-400 dark:text-slate-500 block mb-2">CSS Output Code snippet</span>
      <pre class="bg-slate-950 text-indigo-300 dark:text-indigo-400/90 text-2xs p-3 rounded-lg overflow-x-auto max-h-32 border border-slate-900"><code x-text="`width: ${settings.width}px;
height: ${settings.height}px;
border-radius: ${settings.borderRadius.tl}px ${settings.borderRadius.tr}px ${settings.borderRadius.br}px ${settings.borderRadius.bl}px;
background: ${getCompositeBackground()};
box-shadow: ${[getBoxShadow(), getInnerShadow()].filter(Boolean).join(', ')};
border: ${settings.border.width}px ${settings.border.style} ${settings.border.color};`"></code></pre>
    </div>
  </div>

  <div class="glass-panel p-5 rounded-2xl border border-slate-200/60 dark:border-slate-800/40 flex flex-col h-[550px] z-10">
    <div class="flex items-center justify-between pb-3 border-b border-slate-100 dark:border-slate-800/60 mb-4">
      <h3 class="text-sm font-bold font-outfit text-slate-800 dark:text-slate-100">Bubble Tuner</h3>
      <span class="text-3xs bg-indigo-50 dark:bg-indigo-950/40 text-indigo-500 font-semibold px-2 py-0.5 rounded-full">Reactive editor</span>
    </div>

    <div class="flex gap-1.5 bg-slate-50 dark:bg-slate-950/40 border border-slate-100 dark:border-slate-900 p-1 rounded-lg text-2xs font-semibold mb-4">
      <button @click="editorTab = 'layout'" :class="editorTab === 'layout' ? 'bg-white dark:bg-slate-900 shadow-xs text-indigo-500 font-bold' : 'text-slate-500 hover:text-slate-700 dark:hover:text-slate-300'" class="flex-1 py-1 rounded transition-all duration-200 cursor-pointer">Layout</button>
      <button @click="editorTab = 'color'" :class="editorTab === 'color' ? 'bg-white dark:bg-slate-900 shadow-xs text-indigo-500 font-bold' : 'text-slate-500 hover:text-slate-700 dark:hover:text-slate-300'" class="flex-1 py-1 rounded transition-all duration-200 cursor-pointer">Colors</button>
      <button @click="editorTab = 'effects'" :class="editorTab === 'effects' ? 'bg-white dark:bg-slate-900 shadow-xs text-indigo-500 font-bold' : 'text-slate-500 hover:text-slate-700 dark:hover:text-slate-300'" class="flex-1 py-1 rounded transition-all duration-200 cursor-pointer">Effects</button>
    </div>

    <div class="flex-1 overflow-y-auto pr-1 space-y-4 text-xs">
      <div x-show="editorTab === 'layout'" class="space-y-4" x-transition>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1.5 font-semibold">Width</label><input type="number" x-model.number="settings.width" class="w-full px-2 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 font-bold text-center"></div>
          <div><label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1.5 font-semibold">Height</label><input type="number" x-model.number="settings.height" class="w-full px-2 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 font-bold text-center"></div>
        </div>
        <div>
          <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1.5 font-semibold flex justify-between"><span>Border Radius</span><span x-text="settings.borderRadius.tl + 'px'"></span></label>
          <input type="range" min="0" max="100" x-model.number="settings.borderRadius.tl" @input="settings.borderRadius.tr = settings.borderRadius.bl = settings.borderRadius.br = settings.borderRadius.tl" class="w-full h-1 bg-slate-200 dark:bg-slate-800 rounded-lg appearance-none cursor-pointer accent-indigo-500">
        </div>
        <div class="border-t border-slate-100 dark:border-slate-850 pt-4 space-y-3">
          <h4 class="text-3xs uppercase font-extrabold tracking-widest text-slate-400 dark:text-slate-500">Borders</h4>
          <div class="grid grid-cols-2 gap-3">
            <div><label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Width</label><input type="number" x-model.number="settings.border.width" class="w-full px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-center font-bold"></div>
            <div><label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Border Color</label><input type="color" x-model="settings.border.color" class="w-full h-7 border-0 bg-transparent cursor-pointer p-0"></div>
          </div>
        </div>
      </div>

      <div x-show="editorTab === 'color'" class="space-y-4" x-transition style="display: none;">
        <div>
          <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1.5 font-semibold">Background Color</label>
          <div class="flex items-center gap-2"><input type="color" x-model="settings.backgroundColor" class="w-10 h-7 border-0 bg-transparent cursor-pointer p-0"><input type="text" x-model="settings.backgroundColor" class="flex-1 px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 font-mono"></div>
        </div>
        <div class="border-t border-slate-100 dark:border-slate-850 pt-4 space-y-3">
          <h4 class="text-3xs uppercase font-extrabold tracking-widest text-slate-400 dark:text-slate-500">Gradients</h4>
          <div>
            <select x-model="settings.gradientType" class="w-full px-2 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950"><option value="none">None</option><option value="linear">Linear</option><option value="radial">Radial</option><option value="conic">Conic</option></select>
          </div>
          <template x-if="settings.gradientType !== 'none'">
            <div class="space-y-3">
              <div><label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold flex justify-between"><span>Gradient Angle</span><span x-text="settings.gradientAngle + '°'"></span></label><input type="range" min="0" max="360" x-model.number="settings.gradientAngle" class="w-full h-1 bg-slate-200 dark:bg-slate-800 rounded-lg appearance-none cursor-pointer accent-indigo-500"></div>
              <div class="grid grid-cols-2 gap-3">
                <div><label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Stop 1 Color</label><input type="color" x-model="settings.gradientStops[0].color" class="w-full h-7 border-0 bg-transparent cursor-pointer p-0"></div>
                <div><label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Stop 2 Color</label><input type="color" x-model="settings.gradientStops[1].color" class="w-full h-7 border-0 bg-transparent cursor-pointer p-0"></div>
              </div>
            </div>
          </template>
        </div>
      </div>

      <div x-show="editorTab === 'effects'" class="space-y-4" x-transition style="display: none;">
        <div>
          <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Overlay Type</label>
          <select x-model="settings.backgroundOverlayType" class="w-full px-2 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950"><option value="none">None</option><option value="image">Image Url</option><option value="lucide">Lucide Icon</option></select>
        </div>
        <template x-if="settings.backgroundOverlayType === 'lucide'">
          <div class="space-y-3 border-l-2 border-indigo-500/30 pl-3">
            <div><select x-model="settings.backgroundLucideIcon" class="w-full px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 font-bold"><option value="Star">Star</option><option value="Heart">Heart</option><option value="Bell">Bell</option><option value="Sparkles">Sparkles</option><option value="Activity">Activity</option></select></div>
            <div class="grid grid-cols-2 gap-3">
              <div><input type="number" x-model.number="settings.backgroundLucideSize" class="w-full px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-center font-bold"></div>
              <div><input type="number" step="0.05" min="0" max="1" x-model.number="settings.backgroundLucideOpacity" class="w-full px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-center font-bold"></div>
            </div>
          </div>
        </template>
        <template x-if="settings.backgroundOverlayType === 'image'">
          <div class="space-y-3 border-l-2 border-indigo-500/30 pl-3">
            <div><input type="text" x-model="settings.backgroundImageUrl" class="w-full px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-xs"></div>
            <div class="grid grid-cols-2 gap-3">
              <div><select x-model="settings.backgroundImageSize" class="w-full px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-xs font-bold"><option value="contain">Contain</option><option value="cover">Cover</option><option value="auto">Auto</option></select></div>
              <div><input type="number" step="0.05" min="0" max="1" x-model.number="settings.backgroundImageOpacity" class="w-full px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-center font-bold"></div>
            </div>
          </div>
        </template>
        <div class="border-t border-slate-100 dark:border-slate-850 pt-4 space-y-3">
          <h4 class="text-3xs uppercase font-extrabold tracking-widest text-slate-400 dark:text-slate-500">Animations</h4>
          <div class="grid grid-cols-2 gap-3">
            <div><select x-model="settings.animation.type" class="w-full px-2 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-xs"><option value="none">None</option><option value="fadeIn">Fade In</option><option value="pop">Pop In</option><option value="slideUp">Slide Up</option><option value="slideIn">Slide In</option><option value="rise">Rise</option></select></div>
            <div><input type="range" min="0" max="15" x-model.number="settings.idleAnim.amplitude" class="w-full h-1 bg-slate-200 dark:bg-slate-800 rounded-lg appearance-none cursor-pointer accent-indigo-500"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Mount explicitly to global window block to avoid Alpine tree lifecycle race conditions
  window.bubblePreviewController = function(initialSettings) {
    return {
      hovered: false,
      settings: initialSettings,
      copied: false,
      saved: false,
      editorTab: 'layout',

      copySettings() {
        navigator.clipboard.writeText(JSON.stringify(this.settings, null, 2));
        this.copied = true;
        setTimeout(() => this.copied = false, 2000);
      },

      downloadSettings() {
        const dataStr = 'data:text/json;charset=utf-8,' + encodeURIComponent(JSON.stringify(this.settings, null, 2));
        const downloadAnchor = document.createElement('a');
        downloadAnchor.setAttribute('href', dataStr);
        downloadAnchor.setAttribute('download', 'bubble-settings.json');
        document.body.appendChild(downloadAnchor);
        downloadAnchor.click();
        downloadAnchor.remove();
      },

      saveSettings() {
        this.saved = true;
        setTimeout(() => this.saved = false, 2000);
      },

      getGradient() {
        if (this.settings.gradientType === 'none') return '';
        const stops = this.settings.gradientStops.map(s => `${s.color} ${s.pos}%`).join(', ');
        switch (this.settings.gradientType) {
          case 'linear': return `linear-gradient(${this.settings.gradientAngle}deg, ${stops})`;
          case 'radial': return `radial-gradient(circle, ${stops})`;
          case 'conic': return `conic-gradient(from ${this.settings.gradientAngle}deg, ${stops})`;
          default: return '';
        }
      },

      getBoxShadow() {
        const { boxShadowOffsetX, boxShadowOffsetY, boxShadowBlur, boxShadowSpread, boxShadowOpacity } = this.settings;
        return `${boxShadowOffsetX}px ${boxShadowOffsetY}px ${boxShadowBlur}px ${boxShadowSpread}px rgba(0,0,0,${boxShadowOpacity})`;
      },

      getInnerShadow() {
        if (!this.settings.innerShadow.enabled) return '';
        return `inset 0 6px ${this.settings.innerShadow.blur}px rgba(0,0,0,${this.settings.innerShadow.opacity})`;
      },

      getCompositeBackground() {
        return this.settings.gradientType !== 'none' ? this.getGradient() : this.settings.backgroundColor;
      },

      getBorderImage() {
        if (!this.settings.borderGradientEnabled) return '';
        const stops = this.settings.borderGradientStops.map(s => `${s.color} ${s.pos}%`).join(', ');
        return `linear-gradient(${this.settings.borderGradientAngle}deg, ${stops}) 1`;
      },

      getBorderStyle() {
        const style = {
          borderWidth: `${this.settings.border.width}px`,
          borderStyle: this.settings.border.style,
          borderColor: this.settings.border.color
        };
        if (this.settings.borderGradientEnabled) {
          style.borderImage = this.getBorderImage();
          style.borderColor = 'transparent';
        }
        return style;
      },

      getEntryAnimStyle() {
        const duration = `${this.settings.animation.duration}ms`;
        const delay = `${this.settings.animation.delay}ms`;
        const ease = 'cubic-bezier(.2,.8,.2,1)';
        let anim = '';
        if (this.settings.animation.type !== 'none') {
          anim = `${this.settings.animation.type} ${duration} ${ease} ${delay} both`;
        }
        if (this.settings.idleAnim && this.settings.idleAnim.enabled) {
          const idleAnimName = this.settings.idleAnim.type === 'float' ? 'idleFloat' : 'idleBob';
          const idleDuration = `${this.settings.idleAnim.duration}ms`;
          const idleAnimString = `${idleAnimName} ${idleDuration} ease-in-out infinite`;
          anim = anim ? `${anim}, ${idleAnimString}` : idleAnimString;
        }
        return anim ? { animation: anim } : {};
      },

      getNeonStyle() {
        if (!this.settings.neon || !this.settings.neon.enabled) return {};
        const intensity = this.settings.neon.intensity;
        const color = this.settings.neon.color;
        const shadow = this.getBoxShadow();
        return {
          filter: `drop-shadow(0 0 ${10 * intensity}px ${color})`,
          boxShadow: `${shadow}, 0 0 ${10 * intensity}px ${color}, 0 0 ${25 * intensity}px ${color}`
        };
      },

      getGlassStyle() {
        if (!this.settings.glass || !this.settings.glass.enabled) return {};
        return {
          backdropFilter: `blur(${this.settings.glass.blur}px)`,
          backgroundColor: `rgba(255,255,255,${this.settings.glass.bgOpacity})`
        };
      },

      hexToRgba(hex, alpha) {
        const v = hex.replace('#', '');
        const bigint = parseInt(v.length === 3 ? v.split('').map(c => c + c).join('') : v, 16);
        return `rgba(${(bigint >> 16) & 255},${(bigint >> 8) & 255},${bigint & 255},${alpha})`;
      },

      cssKeyframes() {
        return `
          @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
          @keyframes popIn { 0% { transform: scale(.9); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
          @keyframes slideUp { from { transform: translateY(16px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
          @keyframes slideIn { from { transform: translateX(-16px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
          @keyframes rise { from { transform: translateY(24px); filter: blur(6px); opacity: 0; } to { transform: translateY(0); filter: blur(0); opacity: 1; } }
          @keyframes idleFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-${this.settings.idleAnim ? this.settings.idleAnim.amplitude : 6}px); } }
          @keyframes idleBob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-${this.settings.idleAnim ? this.settings.idleAnim.amplitude : 6}px) scale(1.01); } }
          @keyframes dotBounce { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
          @keyframes dotPulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.25); } }
        `;
      },

      init() {
        this.$watch('settings.backgroundLucideIcon', () => {
          this.$nextTick(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); });
        });
        this.$watch('settings.backgroundOverlayType', () => {
          this.$nextTick(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); });
        });
        this.$nextTick(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); });
      }
    };
  };

  // Safe execution layer for Alpine context mapping
  if (window.Alpine) {
    window.Alpine.data('bubblePreviewController', window.bubblePreviewController);
  } else {
    document.addEventListener('alpine:init', () => {
      window.Alpine.data('bubblePreviewController', window.bubblePreviewController);
    });
  }
</script>