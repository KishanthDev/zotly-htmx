<script id="chatbar-settings-data" type="application/json">
  <%- JSON.stringify(chatbarSettings || {}) %>
</script>

<div 
  x-data='window.chatbarPreviewController()'
  class="grid grid-cols-1 lg:grid-cols-3 gap-8"
>

  <div class="lg:col-span-2 flex flex-col gap-4">
    <div class="flex-1 flex items-center justify-center bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-16 min-h-[300px] relative transition-all duration-300">
      
      <div class="absolute top-4 right-4 flex space-x-2 z-10">
        <button @click="copySettings()" :class="copied ? 'bg-emerald-500 text-white' : 'bg-white dark:bg-slate-950 text-slate-600 dark:text-slate-400 border border-slate-200 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-900'" class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-bold shadow-sm transition-all duration-200 cursor-pointer">
          <svg x-show="!copied" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H5.4m1.5 13.5h9.75a1.125 1.125 0 0 0 1.125-1.125V7.875a1.125 1.125 0 0 0-1.125-1.125H5.4M9 13.5h5.625M9 16.5h5.625m-5.625-6h1.5m-1.5 3h1.5" /></svg>
          <svg x-show="copied" style="display: none;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
          <span x-text="copied ? 'Copied!' : 'Copy JSON'"></span>
        </button>

        <button @click="downloadSettings()" class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-bold bg-white dark:bg-slate-950 text-slate-600 dark:text-slate-400 border border-slate-200 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-900 shadow-sm transition-all duration-200 cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
          <span>Download</span>
        </button>

        <button @click="saveSettings()" :class="saved ? 'bg-emerald-500 text-white' : 'bg-indigo-600 hover:bg-indigo-500 text-white'" class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-bold shadow-sm transition-all duration-200 cursor-pointer">
          <svg x-show="!saved" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0 1 11.186 0Z" /></svg>
          <svg x-show="saved" style="display: none;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
          <span x-text="saved ? 'Saved!' : 'Save Widget'"></span>
        </button>
      </div>

      <div 
        class="flex justify-between items-center transition-all duration-200 cursor-pointer"
        @mouseenter="hovered = true"
        @mouseleave="hovered = false"
        :style="{
          width: settings.width + 'px',
          height: settings.height + 'px',
          background: getBackgroundStyle(),
          color: settings.textColor,
          borderRadius: `${settings.borderRadius.tl}px ${settings.borderRadius.tr}px ${settings.borderRadius.br}px ${settings.borderRadius.bl}px`,
          boxShadow: settings.shadow ? '0 2px 8px rgba(0,0,0,0.2)' : 'none',
          padding: '0 12px'
        }"
      >
        <span 
          class="inline-block"
          :style="{
            fontSize: settings.textSize + 'px',
            letterSpacing: settings.letterSpacing + 'px',
          }"
          x-text="settings.text || 'Chat with us'"
        ></span>

        <div class="flex items-center justify-center">
          <template x-if="settings.iconType === 'lucide' && settings.lucideIcon">
            <i 
              :data-lucide="toKebabCase(settings.lucideIcon)" 
              :style="{ 
                color: settings.iconColor,
                width: settings.iconWidth + 'px',
                height: settings.iconHeight + 'px',
                opacity: hovered ? 1 : 0.8
              }"
            ></i>
          </template>

          <template x-if="settings.iconType === 'image' && settings.iconImageUrl">
            <img 
              :src="settings.iconImageUrl" 
              alt="icon" 
              class="rounded"
              :style="{
                objectFit: settings.iconFit,
                opacity: settings.iconOpacity,
                width: settings.iconWidth + 'px',
                height: settings.iconHeight + 'px',
                mixBlendMode: settings.iconBlend
              }"
            />
          </template>
        </div>
      </div>

    </div>

    <div class="glass-panel p-4 rounded-xl border border-slate-200/60 dark:border-slate-800/40">
      <span class="text-3xs font-extrabold uppercase tracking-widest text-slate-400 dark:text-slate-500 block mb-2">CSS Output Code snippet</span>
      <pre class="bg-slate-950 text-indigo-300 dark:text-indigo-400/90 text-2xs p-3 rounded-lg overflow-x-auto max-h-36 border border-slate-900"><code x-text="`.chat-bar-widget {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: ${settings.width}px;
  height: ${settings.height}px;
  background: ${getBackgroundStyle()};
  color: ${settings.textColor};
  border-radius: ${settings.borderRadius ? `${settings.borderRadius.tl}px ${settings.borderRadius.tr}px ${settings.borderRadius.br}px ${settings.borderRadius.bl}px` : '20px'};
  box-shadow: ${settings.shadow ? '0 4px 14px rgba(0, 123, 255, 0.35)' : 'none'};
  padding: 0 14px;
  cursor: pointer;
  font-family: var(--font-inter);
  font-weight: 600;
  font-size: ${settings.textSize || 14}px;
}`"></code></pre>
    </div>
  </div>

  <div class="glass-panel p-5 rounded-2xl border border-slate-200/60 dark:border-slate-800/40 flex flex-col h-[550px] z-10">
    <div class="flex items-center justify-between pb-3 border-b border-slate-100 dark:border-slate-800/60 mb-4">
      <h3 class="text-sm font-bold font-outfit text-slate-800 dark:text-slate-100">ChatBar Tuner</h3>
      <span class="text-3xs bg-indigo-50 dark:bg-indigo-950/40 text-indigo-500 font-semibold px-2 py-0.5 rounded-full">Reactive editor</span>
    </div>

    <div class="flex gap-1 bg-slate-50 dark:bg-slate-950/40 border border-slate-100 dark:border-slate-900 p-1 rounded-lg text-2xs font-semibold mb-4 overflow-x-auto">
      <button @click="editorTab = 'layout'" :class="editorTab === 'layout' ? 'bg-white dark:bg-slate-900 shadow-xs text-indigo-500 font-bold' : 'text-slate-500 hover:text-slate-700 dark:hover:text-slate-300'" class="flex-1 py-1 px-1.5 rounded transition-all duration-200 cursor-pointer whitespace-nowrap">Layout</button>
      <button @click="editorTab = 'content'" :class="editorTab === 'content' ? 'bg-white dark:bg-slate-900 shadow-xs text-indigo-500 font-bold' : 'text-slate-500 hover:text-slate-700 dark:hover:text-slate-300'" class="flex-1 py-1 px-1.5 rounded transition-all duration-200 cursor-pointer whitespace-nowrap">Content</button>
      <button @click="editorTab = 'icon'" :class="editorTab === 'icon' ? 'bg-white dark:bg-slate-900 shadow-xs text-indigo-500 font-bold' : 'text-slate-500 hover:text-slate-700 dark:hover:text-slate-300'" class="flex-1 py-1 px-1.5 rounded transition-all duration-200 cursor-pointer whitespace-nowrap">Icon</button>
      <button @click="editorTab = 'style'" :class="editorTab === 'style' ? 'bg-white dark:bg-slate-900 shadow-xs text-indigo-500 font-bold' : 'text-slate-500 hover:text-slate-700 dark:hover:text-slate-300'" class="flex-1 py-1 px-1.5 rounded transition-all duration-200 cursor-pointer whitespace-nowrap">Style</button>
    </div>

    <div class="flex-1 overflow-y-auto pr-1 space-y-4 text-xs">
      
      <div x-show="editorTab === 'layout'" class="space-y-4" x-transition>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1.5 font-semibold">Width (px)</label>
            <input type="number" x-model.number="settings.width" class="w-full px-2 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 font-bold text-center">
          </div>
          <div>
            <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1.5 font-semibold">Height (px)</label>
            <input type="number" x-model.number="settings.height" class="w-full px-2 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 font-bold text-center">
          </div>
        </div>

        <div>
          <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1.5 font-semibold flex justify-between">
            <span>Border Radius</span>
            <span x-text="settings.borderRadius.tl + 'px'"></span>
          </label>
          <input type="range" min="0" max="64" x-model.number="settings.borderRadius.tl" @input="settings.borderRadius.tr = settings.borderRadius.bl = settings.borderRadius.br = settings.borderRadius.tl" class="w-full h-1 bg-slate-200 dark:bg-slate-800 rounded-lg appearance-none cursor-pointer accent-indigo-500">
        </div>

        <div class="border-t border-slate-100 dark:border-slate-850 pt-3">
          <div class="flex items-center justify-between">
            <h4 class="text-3xs uppercase font-extrabold tracking-widest text-slate-400 dark:text-slate-500">Enable Drop Shadow</h4>
            <input type="checkbox" x-model="settings.shadow" class="rounded border-slate-300 dark:border-slate-700 text-indigo-600 focus:ring-indigo-500 cursor-pointer">
          </div>
        </div>
      </div>

      <div x-show="editorTab === 'content'" class="space-y-4" x-transition style="display: none;">
        <div>
          <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1.5 font-semibold">ChatBar Text</label>
          <input type="text" x-model="settings.text" class="w-full px-2 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 font-bold">
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1.5 font-semibold">Text Size (px)</label>
            <input type="number" x-model.number="settings.textSize" class="w-full px-2 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-center font-bold">
          </div>
          <div>
            <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1.5 font-semibold">Letter Spacing</label>
            <input type="number" x-model.number="settings.letterSpacing" class="w-full px-2 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-center font-bold">
          </div>
        </div>
      </div>

      <div x-show="editorTab === 'icon'" class="space-y-4" x-transition style="display: none;">
        <div>
          <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Icon Type</label>
          <select x-model="settings.iconType" class="w-full px-2 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950">
            <option value="lucide">Lucide Icon</option>
            <option value="image">Custom Image</option>
          </select>
        </div>

        <template x-if="settings.iconType === 'lucide'">
          <div class="space-y-3 border-l-2 border-indigo-500/30 pl-3">
            <div>
              <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Select Icon</label>
              <select x-model="settings.lucideIcon" class="w-full px-2 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 font-bold">
                <option value="MessageCircle">MessageCircle</option>
                <option value="Heart">Heart</option>
                <option value="Star">Star</option>
                <option value="Send">Send</option>
                <option value="User">User</option>
              </select>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Icon Width</label>
                <input type="number" x-model.number="settings.iconWidth" class="w-full px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-center font-bold">
              </div>
              <div>
                <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Icon Height</label>
                <input type="number" x-model.number="settings.iconHeight" class="w-full px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-center font-bold">
              </div>
            </div>
            <div>
              <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Icon Color</label>
              <div class="flex items-center gap-1">
                <input type="color" x-model="settings.iconColor" class="w-8 h-7 border-0 bg-transparent cursor-pointer p-0">
                <input type="text" x-model="settings.iconColor" class="flex-1 px-1.5 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 font-mono text-3xs">
              </div>
            </div>
          </div>
        </template>

        <template x-if="settings.iconType === 'image'">
          <div class="space-y-3 border-l-2 border-indigo-500/30 pl-3">
            <div>
              <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Image URL</label>
              <input type="text" x-model="settings.iconImageUrl" class="w-full px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-xs">
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Object Fit</label>
                <select x-model="settings.iconFit" class="w-full px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-xs">
                  <option value="contain">Contain</option>
                  <option value="cover">Cover</option>
                  <option value="fill">Fill</option>
                </select>
              </div>
              <div>
                <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Opacity</label>
                <input type="number" step="0.1" min="0" max="1" x-model.number="settings.iconOpacity" class="w-full px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-center font-bold">
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Width</label>
                <input type="number" x-model.number="settings.iconWidth" class="w-full px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-center font-bold">
              </div>
              <div>
                <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Height</label>
                <input type="number" x-model.number="settings.iconHeight" class="w-full px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-center font-bold">
              </div>
            </div>
            <div>
              <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Blend Mode</label>
              <select x-model="settings.iconBlend" class="w-full px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-xs">
                <option value="normal">Normal</option>
                <option value="multiply">Multiply</option>
                <option value="screen">Screen</option>
                <option value="overlay">Overlay</option>
              </select>
            </div>
          </div>
        </template>
      </div>

      <div x-show="editorTab === 'style'" class="space-y-4" x-transition style="display: none;">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1.5 font-semibold">Background</label>
            <div class="flex items-center gap-1">
              <input type="color" x-model="settings.bgColor" class="w-8 h-7 border-0 bg-transparent cursor-pointer p-0">
              <input type="text" x-model="settings.bgColor" class="flex-1 px-1.5 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 font-mono text-3xs">
            </div>
          </div>
          <div>
            <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1.5 font-semibold">Text Color</label>
            <div class="flex items-center gap-1">
              <input type="color" x-model="settings.textColor" class="w-8 h-7 border-0 bg-transparent cursor-pointer p-0">
              <input type="text" x-model="settings.textColor" class="flex-1 px-1.5 py-1 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 font-mono text-3xs">
            </div>
          </div>
        </div>

        <div class="border-t border-slate-100 dark:border-slate-850 pt-3 space-y-3">
          <div class="flex items-center justify-between">
            <h4 class="text-3xs uppercase font-extrabold tracking-widest text-slate-400 dark:text-slate-500">Enable Gradient</h4>
            <input type="checkbox" x-model="settings.gradientEnabled" class="rounded border-slate-300 dark:border-slate-700 text-indigo-600 focus:ring-indigo-500 cursor-pointer">
          </div>

          <template x-if="settings.gradientEnabled">
            <div class="space-y-3 border-l-2 border-indigo-500/30 pl-3">
              <div>
                <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Type</label>
                <select x-model="settings.gradientType" class="w-full px-2 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950">
                  <option value="linear">Linear</option>
                  <option value="radial">Radial</option>
                  <option value="conic">Conic</option>
                </select>
              </div>

              <div>
                <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold flex justify-between">
                  <span>Gradient Angle</span>
                  <span x-text="settings.gradientAngle + '°'"></span>
                </label>
                <input type="range" min="0" max="360" x-model.number="settings.gradientAngle" class="w-full h-1 bg-slate-200 dark:bg-slate-800 rounded-lg appearance-none cursor-pointer accent-indigo-500">
              </div>

              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Stop 1 Color</label>
                  <input type="color" x-model="settings.gradientStops[0].color" class="w-full h-7 border-0 bg-transparent cursor-pointer p-0">
                </div>
                <div>
                  <label class="block text-3xs uppercase tracking-wider text-slate-500 mb-1 font-semibold">Stop 2 Color</label>
                  <input type="color" x-model="settings.gradientStops[1].color" class="w-full h-7 border-0 bg-transparent cursor-pointer p-0">
                </div>
              </div>
            </div>
          </template>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Global Controller Definition
  window.chatbarPreviewController = function() {
    let initialSettings = {};
    
    // Safely parse JSON from script tag
    try {
      initialSettings = JSON.parse(document.getElementById('chatbar-settings-data').textContent);
    } catch (e) {
      console.error("Failed to parse initial chatbar settings", e);
    }

    // Apply defaults to handle missing or undefined attributes
    const defaultSettings = {
      text: "Chat with us",
      bgColor: "#007bff",
      textColor: "#ffffff",
      textSize: 14,
      letterSpacing: 0,
      gradientEnabled: false,
      gradientStops: [
        { color: "#007bff", pos: 0 },
        { color: "#a855f7", pos: 100 }
      ],
      gradientType: "linear",
      gradientAngle: 90,
      iconType: "lucide",
      iconColor: "#ffffff",
      lucideIcon: "MessageCircle",
      iconImageUrl: "",
      iconFit: "contain",
      iconOpacity: 1,
      iconBlend: "normal",
      iconWidth: 20,
      iconHeight: 20,
      width: 255,
      height: 40,
      shadow: true,
      ...initialSettings,
      borderRadius: {
        tl: 20, tr: 20, bl: 20, br: 20,
        ...(initialSettings.borderRadius || {})
      }
    };

    return {
      settings: defaultSettings,
      hovered: false,
      copied: false,
      saved: false,
      editorTab: 'layout',

      copySettings() {
        navigator.clipboard.writeText(JSON.stringify(this.settings, null, 2));
        this.copied = true;
        setTimeout(() => this.copied = false, 2000);
      },

      downloadSettings() {
        const dataStr = 'data:text/json;charset=utf-8,' + encodeURIComponent(JSON.stringify(this.settings, null, 2));
        const downloadAnchor = document.createElement('a');
        downloadAnchor.setAttribute('href', dataStr);
        downloadAnchor.setAttribute('download', 'chatbar-settings.json');
        document.body.appendChild(downloadAnchor);
        downloadAnchor.click();
        downloadAnchor.remove();
      },

      saveSettings() {
        this.saved = true;
        setTimeout(() => this.saved = false, 2000);
      },

      getBackgroundStyle() {
        if (!this.settings.gradientEnabled) return this.settings.bgColor;
        const stops = this.settings.gradientStops.map(s => `${s.color} ${s.pos}%`).join(', ');
        switch (this.settings.gradientType) {
          case 'linear': return `linear-gradient(${this.settings.gradientAngle}deg, ${stops})`;
          case 'radial': return `radial-gradient(circle, ${stops})`;
          case 'conic': return `conic-gradient(from ${this.settings.gradientAngle}deg, ${stops})`;
          default: return this.settings.bgColor;
        }
      },

      // Helper to convert React PascalCase "MessageCircle" to HTML data-lucide "message-circle"
      toKebabCase(str) {
        if (!str) return '';
        return str.replace(/([a-z0-9])([A-Z])/g, '$1-$2').toLowerCase();
      },

      init() {
        // Force Lucide to re-parse the DOM when the icon name or type changes
        this.$watch('settings.lucideIcon', () => {
          this.$nextTick(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); });
        });
        
        this.$watch('settings.iconType', () => {
          this.$nextTick(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); });
        });

        // Parse icons on initial mount
        this.$nextTick(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); });
      }
    };
  };

  // Safe registration fallback
  if (window.Alpine) {
    window.Alpine.data('chatbarPreviewController', window.chatbarPreviewController);
  } else {
    document.addEventListener('alpine:init', () => {
      window.Alpine.data('chatbarPreviewController', window.chatbarPreviewController);
    });
  }
</script>
