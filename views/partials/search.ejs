<section x-show="currentTab === 'search'" class="space-y-6" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-3" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;">
  
  <div class="p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-900/60 shadow-xs dark:shadow-md">
    <h3 class="text-sm uppercase tracking-wider font-extrabold text-slate-400 dark:text-slate-500 mb-2">Active Database Search</h3>
    <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed mb-6">
      Search is triggered dynamically as you type (debounced by 300ms to avoid overwhelming the server). The server returns pre-rendered HTML snippets that update the list directly.
    </p>

    <!-- Search Input Form -->
    <div class="relative max-w-lg mb-6">
      <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.637 10.637Z" />
        </svg>
      </span>
      <input 
        type="search" 
        name="q"
        placeholder="Search stack components (e.g. HTMX, Alpine, Rust)..." 
        hx-get="/api/search" 
        hx-trigger="keyup changed delay:300ms, search" 
        hx-target="#search-results" 
        hx-indicator="#search-indicator"
        class="w-full pl-11 pr-12 py-3 rounded-2xl bg-white dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all duration-200"
      />
      
      <!-- Loading Indicator Spinner -->
      <span id="search-indicator" class="htmx-indicator absolute inset-y-0 right-0 pr-3.5 flex items-center">
        <svg class="animate-spin h-5 w-5 text-indigo-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      </span>
    </div>

    <!-- Dynamic Search Results Target Container -->
    <div 
      id="search-results" 
      hx-get="/api/search" 
      hx-trigger="load"
      class="grid grid-cols-1 sm:grid-cols-2 gap-4"
    >
      <!-- Loading Cards skeleton initially -->
      <div class="h-28 rounded-2xl bg-slate-50 dark:bg-slate-950 border border-slate-100 dark:border-slate-800 animate-pulse"></div>
      <div class="h-28 rounded-2xl bg-slate-50 dark:bg-slate-950 border border-slate-100 dark:border-slate-800 animate-pulse"></div>
    </div>
  </div>
</section>
