<section x-show="currentTab === 'tasks'" class="space-y-6" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-3" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;">
  
  <div class="p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-900/60 shadow-xs dark:shadow-md max-w-2xl">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm uppercase tracking-wider font-extrabold text-slate-400 dark:text-slate-500">Live Task Board</h3>
      <span class="text-2xs text-indigo-500 font-semibold bg-indigo-50 dark:bg-indigo-950/20 px-2 py-0.5 rounded-full">Reactive Synced</span>
    </div>
    <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed mb-6">
      Add, toggle or delete tasks. The server validates the form, processes the updates, returns updated elements, and pushes <strong>Out-of-Band (OOB)</strong> DOM updates to sync the header task badge dynamically!
    </p>

    <!-- Add Task Form -->
    <form 
      hx-post="/api/tasks" 
      hx-target="#tasks-list" 
      hx-swap="beforeend" 
      hx-on::after-request="if(event.detail.successful) this.reset()"
      class="mb-6"
    >
      <div class="flex flex-col sm:flex-row gap-2">
        <div class="flex-1">
          <input 
            type="text" 
            name="text" 
            placeholder="What is your next goal?" 
            class="w-full px-4 py-2.5 rounded-xl bg-white dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all duration-200"
          />
          <!-- Error Validation target -->
          <div id="validation-msg"></div>
        </div>
        <button 
          type="submit" 
          class="px-5 py-2.5 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-semibold text-sm shadow-md cursor-pointer flex items-center justify-center gap-1.5 transition-all duration-200"
        >
          <span>Add</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
        </button>
      </div>
    </form>

    <!-- Task List Target Container -->
    <ul 
      id="tasks-list" 
      hx-get="/api/tasks" 
      hx-trigger="load"
      class="space-y-2.5"
    >
      <!-- Loading Skeletons -->
      <li class="h-12 rounded-xl bg-slate-50 dark:bg-slate-950/40 animate-pulse border border-slate-100 dark:border-slate-800"></li>
      <li class="h-12 rounded-xl bg-slate-50 dark:bg-slate-950/40 animate-pulse border border-slate-100 dark:border-slate-800"></li>
    </ul>
  </div>
</section>
