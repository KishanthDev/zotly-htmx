<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HTMX + Alpine.js + EJS Modular Dashboard</title>
  
  <!-- Tailwind CSS v4 Browser Compiler CDN -->
  <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
  
  <!-- HTMX v2 CDN -->
  <script src="https://unpkg.com/htmx.org@2.0.0"></script>
  
  <!-- Alpine.js v3 CDN (defer is recommended) -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  
  <!-- Lucide Icons CDN -->
  <script src="https://unpkg.com/lucide@latest"></script>
  
  <!-- Custom Styles (HTMX indicators, fonts, fine-tuning) -->
  <link rel="stylesheet" href="/style.css">
  
  <!-- Tailwind v4 Custom Theme & Utilities via browser compiler -->
  <style type="text/tailwindcss">
    @import "tailwindcss";
    @custom-variant dark (&:where(.dark, .dark *));

    @theme {
      --font-inter: 'Inter', sans-serif;
      --font-outfit: 'Outfit', sans-serif;
    }
  </style>
</head>
