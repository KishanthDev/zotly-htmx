<section x-show="currentTab === 'dashboard'" class="space-y-8" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-3" x-transition:enter-end="opacity-100 translate-y-0">
  
  <div class="p-5 rounded-2xl bg-gradient-to-r from-indigo-500/10 to-violet-500/10 border border-indigo-500/10 dark:border-indigo-400/5">
    <h3 class="text-base font-bold font-outfit text-indigo-600 dark:text-indigo-400 mb-1">Welcome to the HTMX & Alpine.js Sandbox</h3>
    <p class="text-xs md:text-sm text-slate-600 dark:text-slate-400 leading-relaxed max-w-3xl">
      This dashboard demonstrates modern HTML-first reactivity. The metrics below are retrieved from the backend Express server and updated automatically every 3 seconds using HTMX polling, styled natively using Tailwind v4, and dynamic states are managed locally by Alpine.js.
    </p>
  </div>

  <!-- Live Server Metrics: HTMX Polling container -->
  <div class="space-y-3">
    <div class="flex items-center justify-between">
      <h3 class="text-3xs uppercase tracking-widest font-extrabold text-slate-400 dark:text-slate-500">Live Server Telemetry</h3>
      <span class="text-3xs text-slate-400 dark:text-slate-500">Updates every 3s</span>
    </div>
    
    <!-- Trigger: Load immediately, then poll every 3 seconds -->
    <div 
      hx-get="/api/metrics" 
      hx-trigger="load, every 3s" 
      hx-swap="innerHTML"
      class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4"
    >
      <!-- Skeletons loaded initially -->
      <div class="h-36 rounded-2xl bg-slate-50 dark:bg-slate-900 border border-slate-100 dark:border-slate-800 animate-pulse"></div>
      <div class="h-36 rounded-2xl bg-slate-50 dark:bg-slate-900 border border-slate-100 dark:border-slate-800 animate-pulse"></div>
      <div class="h-36 rounded-2xl bg-slate-50 dark:bg-slate-900 border border-slate-100 dark:border-slate-800 animate-pulse"></div>
    </div>
  </div>

  <!-- Alpine.js Demonstration Interactive Panel -->
  <div class="p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-900/60 shadow-xs dark:shadow-md">
    <div class="flex items-center gap-2.5 mb-3 text-indigo-600 dark:text-indigo-400">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75" />
      </svg>
      <h3 class="text-base font-bold font-outfit">Alpine.js Client State Demonstration</h3>
    </div>
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-6">
      Unlike HTMX (which requests server HTML), Alpine.js is perfect for immediate, client-only visual states like filters, calculations, or showing modal dialogues.
    </p>

    <!-- Alpine.js Interactive Widget -->
    <div x-data="{ sliderVal: 4, openModal: false }" class="space-y-6">
      <div class="max-w-md bg-slate-50 dark:bg-slate-950/40 border border-slate-100 dark:border-slate-900/60 rounded-xl p-4">
        <label for="interactive-slider" class="text-xs font-semibold text-slate-500 dark:text-slate-400 flex justify-between mb-2">
          <span>Dynamic Grid Span (Local Alpine State)</span>
          <span class="text-indigo-500 font-bold" x-text="sliderVal + ' Columns'"></span>
        </label>
        <input 
          id="interactive-slider" 
          type="range" 
          min="2" 
          max="6" 
          x-model="sliderVal" 
          class="w-full h-1.5 bg-slate-200 dark:bg-slate-800 rounded-lg appearance-none cursor-pointer accent-indigo-500"
        />
        <!-- Local Reactive Elements Grid changing grid columns dynamically based on Alpine model -->
        <div 
          class="grid gap-2 mt-4 transition-all duration-300"
          :style="'grid-template-columns: repeat(' + sliderVal + ', minmax(0, 1fr))'"
        >
          <template x-for="i in 12" :key="i">
            <div class="h-8 rounded bg-gradient-to-br from-indigo-500/20 to-violet-500/20 border border-indigo-500/10 flex items-center justify-center text-3xs font-semibold text-indigo-600 dark:text-indigo-400" x-text="i"></div>
          </template>
        </div>
      </div>

      <!-- Modal Trigger Button -->
      <div>
        <button 
          @click="openModal = true" 
          class="px-4 py-2 text-xs font-bold text-white bg-indigo-600 hover:bg-indigo-500 rounded-xl shadow-md hover:shadow-lg hover:shadow-indigo-500/20 transition-all duration-200 cursor-pointer"
        >
          Launch Client-Side Dialog Modal
        </button>
      </div>

      <!-- Client-side Dialog Modal handled by Alpine -->
      <div 
        x-show="openModal" 
        class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-950/60 backdrop-blur-xs"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        style="display: none;"
      >
        <div 
          @click.outside="openModal = false" 
          class="w-full max-w-md bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 rounded-2xl p-6 shadow-2xl relative"
          x-transition:enter="transition ease-out duration-300 transform"
          x-transition:enter-start="scale-95 translate-y-4"
          x-transition:enter-end="scale-100 translate-y-0"
        >
          <h4 class="text-lg font-black font-outfit text-slate-800 dark:text-slate-100 mb-2">Alpine Modal Portal</h4>
          <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-6">
            This dialog modal is managed completely on the client side with Alpine.js. Click outside this dialog box or press the button below to close it.
          </p>
          <div class="flex justify-end">
            <button 
              @click="openModal = false" 
              class="px-4 py-2 text-xs font-bold text-slate-700 hover:text-slate-800 dark:text-slate-300 dark:hover:text-slate-100 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-xl transition-all duration-200 cursor-pointer"
            >
              Close Dialog
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
