<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="antialiased">
  
  <div 
    x-data="dashboardController"
    class="min-h-screen bg-white dark:bg-slate-950 text-slate-800 dark:text-slate-200 transition-colors duration-300 font-inter flex flex-col relative"
  >
    <!-- Background Glows -->
    <div class="accent-glow top-[100px] left-[50px]"></div>
    <div class="accent-glow-emerald bottom-[150px] right-[50px]"></div>

    <!-- 1. TOP NAVBAR -->
    <%- include('partials/navbar') %>

    <!-- Main Flex Shell -->
    <div class="flex flex-1 relative min-h-0">

      <!-- 2. SIDEBAR -->
      <%- include('partials/sidebar') %>

      <!-- 3. MAIN CONTENT CONTAINER -->
      <main class="flex-1 p-4 md:p-8 overflow-y-auto w-full z-10">
        <div class="max-w-5xl mx-auto w-full space-y-6">

          <!-- View Title Header -->
          <div class="pb-4 border-b border-slate-100 dark:border-slate-900/60 mb-6">
            <span class="text-3xs uppercase tracking-widest font-extrabold text-indigo-500 font-outfit">Demonstration Panel</span>
            <h2 x-show="currentTab === 'dashboard'" x-transition class="text-2xl font-black font-outfit text-slate-800 dark:text-slate-100 mt-1">Performance & Analytics</h2>
            <h2 x-show="currentTab === 'search'" x-transition class="text-2xl font-black font-outfit text-slate-800 dark:text-slate-100 mt-1" style="display: none;">Interactive Directory</h2>
            <h2 x-show="currentTab === 'tasks'" x-transition class="text-2xl font-black font-outfit text-slate-800 dark:text-slate-100 mt-1" style="display: none;">Reactive Task Manager</h2>
            <h2 x-show="currentTab === 'bubble'" x-transition class="text-2xl font-black font-outfit text-slate-800 dark:text-slate-100 mt-1" style="display: none;">Bubble Pixel Playground</h2>
          </div>

          <!-- Views -->
          <%- include('partials/dashboard') %>
          <%- include('partials/search') %>
          <%- include('partials/tasks') %>
          
          <div x-show="currentTab === 'bubble'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-3" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;">
            <%- include('../widgets/bubble/bubblePreview', { settings: bubbleSettings }) %>
          </div>

        </div>
      </main>

    </div>
  </div>

  <!-- Modular Alpine Controller Script -->
  <script>
    document.addEventListener('alpine:init', () => {
      
      // Theme Persisted Store
      Alpine.store('theme', {
        dark: localStorage.getItem('theme') === 'dark',
        init() {
          this.apply();
        },
        toggle() {
          this.dark = !this.dark;
          localStorage.setItem('theme', this.dark ? 'dark' : 'light');
          this.apply();
        },
        apply() {
          if (this.dark) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        }
      });

      // Sidebar Persisted Store
      Alpine.store('sidebar', {
        expanded: localStorage.getItem('sidebar-expanded') !== 'false',
        mobileOpen: false,
        toggle() {
          this.expanded = !this.expanded;
          localStorage.setItem('sidebar-expanded', this.expanded);
        },
        toggleMobile() {
          this.mobileOpen = !this.mobileOpen;
        }
      });

      // Dashboard View Controller
      Alpine.data('dashboardController', () => ({
        currentTab: 'dashboard',
        setTab(tab) {
          this.currentTab = tab;
          Alpine.store('sidebar').mobileOpen = false;
        }
      }));

    });
  </script>

</body>
</html>
